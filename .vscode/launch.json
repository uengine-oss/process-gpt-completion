{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.venv/Scripts/python.exe"
        },
        {
            "name": "Polling Service",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/polling_service/main.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}/polling_service",
            "envFile": "${workspaceFolder}/polling_service/.env"
        }
    ]
}